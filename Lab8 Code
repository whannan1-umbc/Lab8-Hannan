#include <Wire.h>
#include <LiquidCrystal_I2C.h>

LiquidCrystal_I2C lcd(0x27, 16, 2);   
const int analogPin = A0;
const float vRef = 5.0;

void setup() {
  Serial.begin(9600);
  lcd.init();
  lcd.backlight();
  lcd.clear();
  lcd.setCursor(0, 0);
  lcd.print("Voltage Meter");
  delay(1000);
  lcd.clear();
}

void loop() {
  int raw = analogRead(analogPin);
  float voltage = raw * (vRef / 1023.0);
  Serial.print("Raw = ");
  Serial.print(raw);
  Serial.print("   Voltage = ");
  Serial.println(voltage, 3);
  lcd.setCursor(0, 0);
  lcd.print("Voltage:      ");
  lcd.setCursor(0, 1);
  lcd.print(voltage, 2);
  lcd.print(" V      ");

  delay(500);
}
