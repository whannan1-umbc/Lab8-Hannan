#include <Wire.h>
#include <LiquidCrystal_I2C.h>

LiquidCrystal_I2C lcd(0x27, 16, 2);   
const float vRef = 5.0;
const int analogPin = A0;

void setup() {
# Sets up
  Serial.begin(9600);
  lcd.init();
  lcd.backlight();
  lcd.clear();
  lcd.setCursor(0, 0);
  lcd.print("Voltage Measure");
  delay(1000);
  lcd.clear();
}

void loop() {
# Reads voltage data
  int data = analogRead(analogPin);
  float voltage = data * (vRef / 1023.0);
# Displays voltage
  Serial.print("   Voltage = ");
  Serial.println(voltage, 3);
  lcd.setCursor(0, 0);
  lcd.print("Voltage:      ");
  lcd.setCursor(0, 1);
  lcd.print(voltage, 2);
  lcd.print(" V      ");

  delay(500);
}
